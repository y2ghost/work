<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE generatorConfiguration
	PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
		"http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">
<!-- MyBatis Generator的使用例子 -->
<generatorConfiguration>
	<context id="rvsdbTables" targetRuntime="MyBatis3">
		<commentGenerator>
			<property name="suppressAllComments" value="true" />
		</commentGenerator>
		<jdbcConnection
			connectionURL="jdbc:mariadb://192.168.56.166:3306/rvsdb"
			driverClass="org.mariadb.jdbc.Driver" password="rvs2019forwinner"
			userId="rvs" />
		<javaModelGenerator
			targetPackage="study.ywork.springboot.entity"
			targetProject="springboot/src/main/java" />
		<sqlMapGenerator
			targetPackage="study.ywork.springboot.dao"
			targetProject="springboot/src/main/resources" />
		<javaClientGenerator
			targetPackage="study.ywork.springboot.dao"
			targetProject="springboot/src/main/java" type="XMLMAPPER" />
		<table schema="rvsdb" tableName="rvs_user" />
	</context>
</generatorConfiguration>